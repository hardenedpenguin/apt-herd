# Optional dependency reference (install with gem3.3, not Bundler):
#   sudo gem3.3 install net-ssh ed25519 bcrypt_pbkdf
#
# Prereq: sudo apt install ruby3.3-dev build-essential

source 'https://rubygems.org'
ruby '>= 2.6.0'
gem 'net-ssh', '~> 7.0'
gem 'ed25519', '>= 1.2', '< 2.0'
gem 'bcrypt_pbkdf', '>= 1.0', '< 2.0'
