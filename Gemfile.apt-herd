# apt-herd - Herd apt maintenance across hosts via SSH
# Prereq (Debian): sudo apt install ruby3.3-dev
# Install: bundle3.3 install --gemfile=Gemfile.apt-herd --path vendor/bundle && ./apt-herd.rb
# System-wide: sudo bundle3.3 install --gemfile=Gemfile.apt-herd (always use sudo)
# Or: sudo gem3.3 install net-ssh ed25519 bcrypt_pbkdf

source 'https://rubygems.org'
ruby '>= 2.6.0'
gem 'net-ssh', '~> 7.0'
gem 'ed25519', '>= 1.2', '< 2.0'
gem 'bcrypt_pbkdf', '>= 1.0', '< 2.0'
