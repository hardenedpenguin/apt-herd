# apt-herd - Herd apt update/upgrade across hosts via SSH
# Install: bundle install --gemfile=Gemfile.apt-herd (on Debian, often bundle3.3, etc.)
# Or: gem install net-ssh ed25519 bcrypt_pbkdf

source 'https://rubygems.org'
ruby '>= 2.6.0'
gem 'net-ssh', '~> 7.0'
gem 'ed25519', '>= 1.2', '< 2.0'
gem 'bcrypt_pbkdf', '>= 1.0', '< 2.0'
